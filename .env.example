# Copy this file to .env and edit before running.
# The .env file is gitignored and loaded by compose.yaml.

# First-run admin account (only used when the DB has no users yet)
GANXTERM_ADMIN_USER=admin
GANXTERM_ADMIN_PASS=changeme

# How long a login session stays alive without activity (hours)
SESSION_TTL_HOURS=8

# Login brute-force protection (fixed window per IP, backed by Redis)
#LOGIN_RATE_LIMIT=10
#LOGIN_RATE_WINDOW=900

# Fernet key for encrypting stored SSH/Telnet credentials (base64url, 32 bytes).
# If unset, a key is auto-generated and saved to secret.key in GANXTERM_DATA_DIR.
# To generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#GANXTERM_SECRET_KEY=
